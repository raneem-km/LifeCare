datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Booking {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String?
  phone     String
  email     String?
  reason    String
  symptoms  String?
  mode      String?
  location  String?
  time      String?
  doctor    String?
  date      String
  status    String   @default("Pending")
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Review {
  id        Int      @id @default(autoincrement())
  name      String
  rating    Int
  text      String
  createdAt DateTime @default(now())
}
