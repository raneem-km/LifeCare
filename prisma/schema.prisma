datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Booking {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String?
  phone     String
  reason    String
  date      String
  createdAt DateTime @default(now())
}

model Review {
  id        Int      @id @default(autoincrement())
  name      String
  rating    Int
  text      String
  createdAt DateTime @default(now())
}
